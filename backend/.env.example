# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/carbon-registry

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRE=7d

# Email Configuration (Gmail)
